# =============================================================================
# GridSight.AI — Environment Variables
# =============================================================================
# Copy this file to `.env` (or `.env.local`) and fill in your keys.
# All keys are OPTIONAL — the dashboard runs fine without any of them, falling
# back to NWS (no key) for weather and a synthetic baseline otherwise.
#
# IMPORTANT: Any VITE_* variable is bundled into the client-side JS and is
# publicly visible. EIA + NREL keys are free and rate-limited per-key, so this
# is acceptable for a hackathon demo. For production, proxy through a backend.
# =============================================================================

# --- EIA-930 (Arizona electricity demand, AZPS balancing authority) ---
# Get a free key: https://www.eia.gov/opendata/register.php
VITE_EIA_API_KEY=

# --- NREL Developer Network (solar irradiance for Phoenix) ---
# Get a free key: https://developer.nrel.gov/signup/
VITE_NREL_API_KEY=

# -----------------------------------------------------------------------------
# Shell-style aliases (also accepted at runtime if you `export` them before
# `npm run dev`). Vite only auto-exposes VITE_*-prefixed vars, so prefer the
# variants above. These are kept here for parity with the Python repo.
# -----------------------------------------------------------------------------
# EIA_API_KEY=
# NREL_API_KEY=
